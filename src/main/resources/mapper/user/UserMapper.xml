<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.swpu.equipment.user.mapper.UserMapper">
    <select id="selectByIdentifier" resultType="com.swpu.equipment.user.entity.User">
        SELECT * FROM sys_user 
        WHERE (student_id = #{identifier} OR phone = #{identifier}) 
        AND status = 1
    </select>
</mapper>